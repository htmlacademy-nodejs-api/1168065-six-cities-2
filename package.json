{
  "name": "six-cities",
  "version": "5.0.0",
  "description": "Проект «Шесть городов» от HTML Academy",
  "keywords": [
    "rest",
    "api",
    "node.js"
  ],
  "main": "main.js",
  "scripts": {
    "start": "npm run build && node ./dist/main.rest.js",
    "start:dev": "nodemon",
    "build": "npm run clean && npm run compile",
    "lint": "eslint src/ --ext .ts",
    "compile": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "ts": "node --loader ts-node/esm",
    "mock:server": "json-server ./mocks/mock-server-data.json --port 3123"
  },
  "devDependencies": {
    "@typegoose/typegoose": "13.2.1",
    "@types/convict": "6.1.6",
    "@types/convict-format-with-validator": "6.0.6",
    "@types/node": "25.5.2",
    "@typescript-eslint/eslint-plugin": "6.7.0",
    "@typescript-eslint/parser": "6.7.0",
    "dotenv": "17.3.1",
    "eslint": "8.49.0",
    "eslint-config-htmlacademy": "9.1.1",
    "json-server": "1.0.0-beta.10",
    "pino-pretty": "13.1.3",
    "rimraf": "5.0.1",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  },
  "type": "module",
  "engines": {
    "node": "^18.0.0",
    "npm": ">=8"
  },
  "dependencies": {
    "chalk": "5.6.2",
    "convict": "6.2.5",
    "convict-format-with-validator": "6.2.0",
    "dayjs": "1.11.19",
    "got": "14.6.6",
    "inversify": "6.2.2",
    "mongoose": "9.2.2",
    "nodemon": "3.1.14",
    "pino": "10.3.1",
    "reflect-metadata": "0.2.2",
    "tslib": "2.8.1"
  }
}
